    "cells": [
        {
            "cell_type": "markdown",
            "source": [
                "# Autonomous Economy Swarm with Omni-Oracle\n",
                "\n",
                "This example demonstrates a multi-agent system where agents trade real-time intelligence using the [Omni-Oracle](https://x402.org) payment protocol.\n",
                "\n",
                "## Setup\n",
                "```bash\n",
                "pip install pyautogen x402-omni-oracle\n",
                "```"
            ]
        },
        {
            "cell_type": "code",
            "source": [
                "import omni_oracle.autogen\n",
                "from autogen import AssistantAgent, UserProxyAgent, register_function\n",
                "\n",
                "config_list = [{\"model\": \"gpt-4\", \"api_key\": \"YOUR_OPENAI_KEY\"}]\n",
                "\n",
                "# 1. Define Agents\n",
                "user_proxy = UserProxyAgent(\n",
                "    name=\"Admin\",\n",
                "    system_message=\"Human Admin. Execute functions.\",\n",
                "    code_execution_config={\"work_dir\": \"coding\"}\n",
                ")\n",
                "\n",
                "logistics_agent = AssistantAgent(\n",
                "    name=\"LogisticsManager\",\n",
                "    llm_config={\"config_list\": config_list},\n",
                "    system_message=\"Manage supply chain risks. Use tools.\"\n",
                ")\n",
                "\n",
                "# 2. Register Omni-Oracle Tools\n",
                "register_function(\n",
                "    omni_oracle.autogen.getKLAXThermalRisk,\n",
                "    caller=logistics_agent,\n",
                "    executor=user_proxy,\n",
                "    name=\"getKLAXThermalRisk\",\n",
                "    description=\"Get LAX Thermal Risk\"\n",
                ")\n",
                "\n",
                "# 3. Run\n",
                "user_proxy.initiate_chat(logistics_agent, message=\"Check LAX risks.\")"
            ]
        }
    ]
}