from autogen import AssistantAgent, UserProxyAgent

policy = AssistantAgent("PolicyResearchAgent", system_message="...")
competitor = AssistantAgent("CompetitorAgent", system_message="...")
info = AssistantAgent("InfoSynthAgent", system_message="...")
director = AssistantAgent("StrategyDirectorAgent", system_message="...")
writer = AssistantAgent("StrategyWriterAgent", system_message="...")
copy = AssistantAgent("CopywriterAgent", system_message="...")
review = AssistantAgent("ReviewBoardAgent", system_message="...")

user = UserProxyAgent("User", human_input_mode="NEVER")

user.initiate_chat(policy, message="这是项目背景：XXXX")
policy.send("请竞品分析补充竞品情况", competitor)
competitor.send("请信息整合", info)
info.send("请项目总监出策略框架", director)
director.send("请输出完整策略", writer)
writer.send("请文案按策略写文案", copy)
copy.send("请评审", review)
